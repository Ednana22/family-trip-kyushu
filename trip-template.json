{
  "title": "九州家族旅行 2025",
  "authors": [
    { "initial": "E", "name": "Edna" },
    { "initial": "S", "name": "小姑" }
  ],
  "days": [
    {
      "day": 1,
      "city": "福岡",
      "landmarks": [
        {
          "name": "王貞治棒球紀念館",
          "hours": "一-五 11:00–19:00\n六-日 10:00–19:00",
          "tags": ["推薦"],
          "lat": 33.5898,
          "lng": 130.4205,
          "notes": [
            { "author": "E", "text": "抵達！先去車站周邊逛逛，博多口和筑紫口都有好吃的" },
            { "author": "S", "text": "博多阪急百貨 B1 食品區必逛，地下美食很多" }
          ]
        },
        {
          "name": "天神地下街",
          "hours": "10:00–20:00",
          "tags": ["必買", "推薦"],
          "lat": 33.5902,
          "lng": 130.3985,
          "notes": [
            { "author": "E", "text": "天神地下街超好買，雨天也不怕！藥妝店一間接一間" },
            { "author": "S", "text": "帶小孩逛很方便，不用曬太陽" }
          ]
        }
      ]
    },
    {
      "day": 2,
      "city": "太宰府",
      "landmarks": [
        {
          "name": "太宰府天滿宮參道",
          "hours": "09:00–17:00",
          "tags": ["必買", "推薦"],
          "lat": 33.5210,
          "lng": 130.5320,
          "notes": [
            { "author": "E", "text": "梅枝餅一定要現烤的！Starbucks 也在參道上，造型超特別" },
            { "author": "S", "text": "試吃超多，小孩很開心，各種梅子口味零食" }
          ]
        },
        {
          "name": "太宰府天滿宮",
          "hours": "06:30–19:00（依季節）",
          "tags": ["推薦", "親子友善"],
          "lat": 33.5227,
          "lng": 130.5337,
          "notes": [
            { "author": "E", "text": "學業之神，來拜一下！牛像和梅花照片很美" },
            { "author": "S", "text": "小孩很喜歡拜神儀式，氛圍很好" }
          ]
        }
      ]
    },
    {
      "day": 3,
      "city": "福岡",
      "landmarks": [
        {
          "name": "中洲川端商店街",
          "hours": "10:00–20:00",
          "tags": ["推薦"],
          "lat": 33.5938,
          "lng": 130.4052,
          "notes": [
            { "author": "E", "text": "白天可以逛商店街，那珂川旁散步很舒服" },
            { "author": "S", "text": "超適合親子，商店街寬敞好推車" }
          ]
        },
        {
          "name": "中洲屋台",
          "hours": "18:00–凌晨 01:00",
          "tags": ["推薦", "必吃"],
          "lat": 33.5925,
          "lng": 130.4055,
          "notes": [
            { "author": "E", "text": "福岡最必去！豚骨拉麵配串燒，河邊氣氛超好" },
            { "author": "S", "text": "帶小孩去要早點（18:00），人少比較好坐" }
          ]
        }
      ]
    },
    {
      "day": 4,
      "city": "福岡",
      "landmarks": [
        {
          "name": "海の中道海浜公園",
          "hours": "09:30–17:30（週一休）",
          "tags": ["親子友善", "推薦"],
          "lat": 33.6402,
          "lng": 130.4368,
          "notes": [
            { "author": "E", "text": "超大公園，花田很美，租腳踏車繞一圈很舒服" },
            { "author": "S", "text": "動物區孩子瘋了！可以摸小動物，必來！" }
          ]
        }
      ]
    },
    {
      "day": 5,
      "city": "湯布院",
      "landmarks": [
        {
          "name": "金鱗湖",
          "hours": "全天開放（清晨最美）",
          "tags": ["推薦"],
          "lat": 33.2792,
          "lng": 131.0558,
          "notes": [
            { "author": "E", "text": "清晨霧氣升起像夢境，建議 7:00 前到，遊客少" },
            { "author": "S", "text": "小孩看到大錦鯉超興奮，湖邊鴨子也很可愛" }
          ]
        },
        {
          "name": "湯の坪街道",
          "hours": "10:00–18:00",
          "tags": ["必買", "推薦"],
          "lat": 33.2770,
          "lng": 131.0497,
          "notes": [
            { "author": "E", "text": "布丁和霜淇淋超讚！各種湯布院限定土產在這裡買" },
            { "author": "S", "text": "手作雜貨很多，買了好多伴手禮" }
          ]
        }
      ]
    },
    {
      "day": 6,
      "city": "熊本",
      "landmarks": [
        {
          "name": "熊本城",
          "hours": "09:00–17:00（最終入場 16:30）",
          "tags": ["推薦"],
          "lat": 32.8063,
          "lng": 130.7058,
          "notes": [
            { "author": "E", "text": "整修中但外觀仍壯觀，天守閣重建完成可進入參觀" },
            { "author": "S", "text": "歷史感很強，孩子對武士甲冑很感興趣" }
          ]
        },
        {
          "name": "上通アーケード",
          "hours": "10:00–20:00",
          "tags": ["必買"],
          "lat": 32.8038,
          "lng": 130.7108,
          "notes": [
            { "author": "E", "text": "熊本熊周邊在這裡買最齊全！官方 shop 就在這" },
            { "author": "S", "text": "在地品牌很多，比東京便宜，買了一堆" }
          ]
        }
      ]
    },
    {
      "day": 7,
      "city": "熊本",
      "landmarks": [
        {
          "name": "水前寺成趣園",
          "hours": "08:30–17:00",
          "tags": ["推薦", "親子友善"],
          "lat": 32.7990,
          "lng": 130.7325,
          "notes": [
            { "author": "E", "text": "縮小版富士山日式庭園，安靜優美，最後一天輕鬆散步" },
            { "author": "S", "text": "小孩在庭園追鴿子玩得很開心，門票便宜值得來" }
          ]
        }
      ]
    }
  ]
}
